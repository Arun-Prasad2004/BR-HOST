# PDF.js library (download from https://github.com/mozilla/pdfjs-dist/releases)
client/public/pdfjs-5.4.54-dist/

# Package lock files (optional - uncomment if needed)
# package-lock.json
# client/package-lock.json
# server/package-lock.json
# .pkl files are intentionally tracked (small model files needed for deployment)
# ml-api/model1-api/*.pkl
# ml-api/model2-api/*.pkl

# Very large files (>100MB)
*.safetensors
